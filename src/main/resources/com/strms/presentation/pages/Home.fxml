<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.strms.presentation.controller.pages.HomeController"
      styleClass="page-root">

    <VBox spacing="12" styleClass="home-header">
        <padding>
            <Insets top="48" left="48" right="48" bottom="32"/>
        </padding>
        <Label text="Welcome Back" styleClass="page-title"/>
        <Label fx:id="welcomeLabel" 
               text="Welcome to STRMS" 
               styleClass="page-subtitle"/>
    </VBox>
</VBox>