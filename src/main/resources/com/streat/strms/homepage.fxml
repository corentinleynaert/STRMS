<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.streat.strms.Login">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <TextField fx:id="email_field" promptText="email@company.com" />
    <PasswordField fx:id="password_field" promptText="password" />

    <Label fx:id="errors" text="The email or password is incorrect..." style="-fx-text-fill: red;" managed="false" visible="false" />
    <Button fx:id="login" text="Login" onAction="#login" disable="true" />
</VBox>