<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.application.strms.presentation.controller.LoginController"
           style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);">

    <VBox alignment="CENTER" spacing="30.0"
          style="-fx-background-color: rgba(255, 255, 255, 0.05);
                 -fx-background-radius: 40;
                 -fx-border-color: rgba(255, 255, 255, 0.1);
                 -fx-border-radius: 40;
                 -fx-border-width: 0.5;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 50, 0, 0, 20);
                 -fx-max-width: 420;
                 -fx-max-height: 550;">

        <padding>
            <Insets bottom="50.0" left="40.0" right="40.0" top="50.0"/>
        </padding>

        <VBox alignment="CENTER" spacing="8">
            <Label text="STRMS"
                   style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900; -fx-font-family: 'SF Pro Display', 'Arial'; -fx-letter-spacing: -1;"/>
            <Label text="Welcome back."
                   style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 14px; -fx-font-weight: 400;"/>
        </VBox>

        <VBox spacing="15">
            <TextField fx:id="email_field" promptText="Email"
                       style="-fx-background-color: rgba(255, 255, 255, 0.05);
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: rgba(255,255,255,0.3);
                              -fx-background-radius: 15;
                              -fx-padding: 16;
                              -fx-border-color: rgba(255,255,255,0.1);
                              -fx-border-radius: 15;
                              -fx-font-size: 14px;"/>

            <PasswordField fx:id="password_field" promptText="Password"
                           style="-fx-background-color: rgba(255, 255, 255, 0.05);
                                  -fx-text-fill: white;
                                  -fx-prompt-text-fill: rgba(255,255,255,0.3);
                                  -fx-background-radius: 15;
                                  -fx-padding: 16;
                                  -fx-border-color: rgba(255,255,255,0.1);
                                  -fx-border-radius: 15;
                                  -fx-font-size: 14px;"/>
        </VBox>

        <Label fx:id="errors" text="Invalid credentials"
               style="-fx-text-fill: #ff6b6b; -fx-font-weight: 400; -fx-font-size: 12px;"
               managed="false" visible="false" />

        <Button fx:id="login_button" text="Continue" onAction="#login" disable="true"
                style="-fx-background-color: white;
                       -fx-text-fill: black;
                       -fx-background-radius: 15;
                       -fx-font-weight: 700;
                       -fx-font-size: 15px;
                       -fx-padding: 16 0;
                       -fx-max-width: Infinity;
                       -fx-cursor: hand;"/>

        <Label text="Forgot password?"
               style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 12px; -fx-cursor: hand;"/>
    </VBox>
</StackPane>