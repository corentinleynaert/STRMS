<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.application.strms.presentation.controller.pages.UpdateTaskController"
           styleClass="page-root">

    <VBox alignment="CENTER" spacing="28" styleClass="card add-user-card">
        <padding>
            <Insets bottom="56" left="56" right="56" top="56"/>
        </padding>

        <VBox alignment="CENTER" spacing="12">
            <Label text="Edit Task" styleClass="page-title"/>
            <Label text="Modify task information" styleClass="page-subtitle"/>
        </VBox>

        <VBox spacing="16">
            <Label text="Title" styleClass="form-label"/>
            <TextField fx:id="titleField"
                       styleClass="form-input"
                       promptText="Enter task title"/>

            <Label text="Description" styleClass="form-label"/>
            <TextArea fx:id="descriptionArea"
                      styleClass="form-input"
                      promptText="Enter task description"
                      wrapText="true"
                      prefRowCount="4"/>

            <Label text="Priority" styleClass="form-label"/>
            <ChoiceBox fx:id="priorityChoiceBox"
                       styleClass="form-input"/>

            <Label text="Category" styleClass="form-label"/>
            <ChoiceBox fx:id="categoryChoiceBox"
                       styleClass="form-input"/>

            <Label text="Deadline" styleClass="form-label"/>
            <DatePicker fx:id="deadlinePicker"
                        styleClass="form-input"/>
        </VBox>

        <Label fx:id="errorLabel"
               styleClass="error-label"
               visible="false"
               managed="false"
               wrapText="true"/>

        <VBox spacing="16" alignment="CENTER">
            <Button text="Update Task"
                    fx:id="updateTaskButton"
                    onAction="#updateTask"
                    styleClass="primary-button,form-button"/>

            <Button text="Back"
                    onAction="#goBack"
                    styleClass="secondary-button,secondary-text"/>
        </VBox>
    </VBox>
</StackPane>
