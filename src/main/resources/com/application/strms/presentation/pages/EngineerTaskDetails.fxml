<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.application.strms.presentation.controller.pages.EngineerTaskDetailsController"
            styleClass="page-root">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="header-padding">
                <Button text="← Back"
                        onAction="#goBack"
                        styleClass="secondary-button,back-button"/>
                <Label fx:id="taskTitleLabel"
                       text="Task Details"
                       styleClass="page-title"
                       HBox.hgrow="ALWAYS"/>
            </HBox>
            <HBox styleClass="divider-subtle"/>
        </VBox>
    </top>

    <center>
        <ScrollPane styleClass="scroll-pane" fitToWidth="true">
            <VBox spacing="20" styleClass="content-padding-large">

                <VBox spacing="16" styleClass="card,card-light">
                    <Label text="Task Information" styleClass="form-label,info-label"/>
                    
                    <GridPane hgap="32" vgap="12">
                        <columnConstraints>
                            <javafx.scene.layout.ColumnConstraints percentWidth="25" minWidth="150"/>
                            <javafx.scene.layout.ColumnConstraints percentWidth="25" minWidth="150"/>
                            <javafx.scene.layout.ColumnConstraints percentWidth="25" minWidth="150"/>
                            <javafx.scene.layout.ColumnConstraints percentWidth="25" minWidth="150"/>
                        </columnConstraints>

                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Title" styleClass="info-label-small"/>
                            <Label fx:id="titleValue" styleClass="form-value,info-value"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Status" styleClass="info-label-small"/>
                            <Label fx:id="statusValue" styleClass="form-value,info-value-highlighted"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label text="Priority" styleClass="info-label-small"/>
                            <Label fx:id="priorityValue" styleClass="form-value,info-value"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <Label text="Category" styleClass="info-label-small"/>
                            <Label fx:id="categoryValue" styleClass="form-value,info-value"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                            <Label text="Deadline" styleClass="info-label-small"/>
                            <Label fx:id="deadlineValue" styleClass="form-value,info-value"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <VBox spacing="12" styleClass="card,card-white">
                    <Label text="Description" styleClass="form-label,info-label"/>
                    <TextArea fx:id="descriptionArea"
                              styleClass="form-input,textarea-white"
                              wrapText="true"
                              prefRowCount="6"
                              editable="false"/>
                </VBox>

                <VBox spacing="12" styleClass="card,card-white">
                    <Label text="Dependencies" styleClass="form-label,info-label"/>
                    
                    <ListView fx:id="dependenciesList"
                              prefHeight="140"
                              styleClass="form-input,list-light"/>
                    
                    <Label fx:id="noDependenciesLabel"
                           text="No dependencies for this task"
                           styleClass="page-subtitle,empty-state-text"
                           managed="false"
                           visible="false"/>
                </VBox>

                <VBox spacing="12" styleClass="card,card-white">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="Activity History" styleClass="form-label,info-label" HBox.hgrow="ALWAYS"/>
                        <Button
                                text="+ Add Note"
                                onAction="#handleAddNote"
                                styleClass="secondary-button,action-button-small"/>
                    </HBox>
                    
                    <ListView fx:id="historyList"
                              prefHeight="160"
                              styleClass="form-input,list-light"/>
                    
                    <Label fx:id="noHistoryLabel"
                           text="No activity history yet"
                           styleClass="page-subtitle,empty-state-text"
                           managed="false"
                           visible="false"/>
                </VBox>
                
                <HBox alignment="CENTER" spacing="16" styleClass="button-section">
                    <Button fx:id="startButton"
                            text="▶ Start Task"
                            onAction="#handleStartTask"
                            styleClass="primary-button,action-button-large"/>
                    <Button fx:id="completeButton"
                            text="✓ Complete Task"
                            onAction="#handleCompleteTask"
                            styleClass="primary-button,action-button-large"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
