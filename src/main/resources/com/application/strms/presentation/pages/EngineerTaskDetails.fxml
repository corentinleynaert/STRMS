<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.application.strms.presentation.controller.pages.EngineerTaskDetailsController"
            styleClass="page-root">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 24 48 20 48;">
                <Button text="← Back"
                        onAction="#goBack"
                        styleClass="secondary-button"
                        style="-fx-text-fill: #888888; -fx-padding: 8 16 8 16;"/>
                <Label fx:id="taskTitleLabel"
                       text="Task Details"
                       styleClass="page-title"
                       HBox.hgrow="ALWAYS"/>
            </HBox>
            <HBox style="-fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane styleClass="scroll-pane" fitToWidth="true" style="-fx-padding: 0;">
            <VBox spacing="20" style="-fx-padding: 32 48 48 48;">

                <VBox spacing="16" styleClass="card" style="-fx-padding: 24; -fx-border-radius: 4; -fx-background-color: #fafafa;">
                    <Label text="Task Information" styleClass="form-label" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    
                    <GridPane hgap="32" vgap="12">
                        <columnConstraints>
                            <javafx.scene.layout.ColumnConstraints percentWidth="25" minWidth="150"/>
                            <javafx.scene.layout.ColumnConstraints percentWidth="25" minWidth="150"/>
                            <javafx.scene.layout.ColumnConstraints percentWidth="25" minWidth="150"/>
                            <javafx.scene.layout.ColumnConstraints percentWidth="25" minWidth="150"/>
                        </columnConstraints>

                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Title" styleClass="form-label" style="-fx-font-size: 11; -fx-text-fill: #666666;"/>
                            <Label fx:id="titleValue" styleClass="form-value" style="-fx-font-size: 12; -fx-text-fill: #333333;"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Status" styleClass="form-label" style="-fx-font-size: 11; -fx-text-fill: #666666;"/>
                            <Label fx:id="statusValue" styleClass="form-value" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1976D2;"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label text="Priority" styleClass="form-label" style="-fx-font-size: 11; -fx-text-fill: #666666;"/>
                            <Label fx:id="priorityValue" styleClass="form-value" style="-fx-font-size: 12; -fx-text-fill: #333333;"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <Label text="Category" styleClass="form-label" style="-fx-font-size: 11; -fx-text-fill: #666666;"/>
                            <Label fx:id="categoryValue" styleClass="form-value" style="-fx-font-size: 12; -fx-text-fill: #333333;"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                            <Label text="Deadline" styleClass="form-label" style="-fx-font-size: 11; -fx-text-fill: #666666;"/>
                            <Label fx:id="deadlineValue" styleClass="form-value" style="-fx-font-size: 12; -fx-text-fill: #333333;"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <VBox spacing="12" styleClass="card" style="-fx-padding: 24; -fx-border-radius: 4; -fx-background-color: #ffffff;">
                    <Label text="Description" styleClass="form-label" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    <TextArea fx:id="descriptionArea"
                              styleClass="form-input"
                              wrapText="true"
                              prefRowCount="6"
                              editable="false"
                              style="-fx-font-size: 11; -fx-control-inner-background: #ffffff; -fx-text-fill: #333333;"/>
                </VBox>

                <VBox spacing="12" styleClass="card" style="-fx-padding: 24; -fx-border-radius: 4; -fx-background-color: #ffffff;">
                    <Label text="Dependencies" styleClass="form-label" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                    
                    <ListView fx:id="dependenciesList"
                              prefHeight="140"
                              styleClass="form-input"
                              style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0;"/>
                    
                    <Label fx:id="noDependenciesLabel"
                           text="No dependencies for this task"
                           styleClass="page-subtitle"
                           style="-fx-text-fill: #999999; -fx-font-size: 11;"
                           managed="false"
                           visible="false"/>
                </VBox>

                <VBox spacing="12" styleClass="card" style="-fx-padding: 24; -fx-border-radius: 4; -fx-background-color: #ffffff;">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="Activity History" styleClass="form-label" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333333;" HBox.hgrow="ALWAYS"/>
                        <Button
                                text="+ Add Note"
                                onAction="#handleAddNote"
                                styleClass="secondary-button"
                                style="-fx-padding: 8 16 8 16; -fx-font-size: 11;"/>
                    </HBox>
                    
                    <ListView fx:id="historyList"
                              prefHeight="160"
                              styleClass="form-input"
                              style="-fx-background-color: #fafafa; -fx-border-color: #e0e0e0;"/>
                    
                    <Label fx:id="noHistoryLabel"
                           text="No activity history yet"
                           styleClass="page-subtitle"
                           style="-fx-text-fill: #999999; -fx-font-size: 11;"
                           managed="false"
                           visible="false"/>
                </VBox>
                
                <HBox alignment="CENTER" spacing="16" style="-fx-padding: 24 0 0 0;">
                    <Button fx:id="startButton"
                            text="▶ Start Task"
                            onAction="#handleStartTask"
                            styleClass="primary-button"
                            style="-fx-min-width: 160; -fx-padding: 12 24 12 24; -fx-font-size: 12;"/>
                    <Button fx:id="completeButton"
                            text="✓ Complete Task"
                            onAction="#handleCompleteTask"
                            styleClass="primary-button"
                            style="-fx-min-width: 160; -fx-padding: 12 24 12 24; -fx-font-size: 12;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
