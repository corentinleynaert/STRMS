<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.application.strms.presentation.controller.AddUser"
           style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b);"
           stylesheets="@app.css">

    <VBox alignment="CENTER" spacing="30.0"
          style="-fx-background-color: rgba(255, 255, 255, 0.05);
                 -fx-background-radius: 40;
                 -fx-border-color: rgba(255, 255, 255, 0.1);
                 -fx-border-radius: 40;
                 -fx-border-width: 0.5;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 50, 0, 0, 20);
                 -fx-max-width: 420;
                 -fx-max-height: 650;">

        <padding>
            <Insets bottom="50.0" left="40.0" right="40.0" top="50.0"/>
        </padding>

        <VBox alignment="CENTER" spacing="8">
            <Label text="STRMS"
                   style="-fx-text-fill: white;
                          -fx-font-size: 32px;
                          -fx-font-weight: 900;
                          -fx-font-family: 'SF Pro Display', 'Arial';
                          -fx-letter-spacing: -1;"/>
            <Label text="Create a new user."
                   style="-fx-text-fill: rgba(255,255,255,0.6);
                          -fx-font-size: 14px;
                          -fx-font-weight: 400;"/>
        </VBox>

        <VBox spacing="15">
            <TextField fx:id="name_field" promptText="Name"
                       style="-fx-background-color: rgba(255, 255, 255, 0.05);
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: rgba(255,255,255,0.3);
                              -fx-background-radius: 15;
                              -fx-padding: 16;
                              -fx-border-color: rgba(255,255,255,0.1);
                              -fx-border-radius: 15;
                              -fx-font-size: 14px;"/>

            <TextField fx:id="email_field" promptText="Email"
                       style="-fx-background-color: rgba(255, 255, 255, 0.05);
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: rgba(255,255,255,0.3);
                              -fx-background-radius: 15;
                              -fx-padding: 16;
                              -fx-border-color: rgba(255,255,255,0.1);
                              -fx-border-radius: 15;
                              -fx-font-size: 14px;"/>

            <PasswordField fx:id="password_field" promptText="Password"
                           style="-fx-background-color: rgba(255, 255, 255, 0.05);
                                  -fx-text-fill: white;
                                  -fx-prompt-text-fill: rgba(255,255,255,0.3);
                                  -fx-background-radius: 15;
                                  -fx-padding: 16;
                                  -fx-border-color: rgba(255,255,255,0.1);
                                  -fx-border-radius: 15;
                                  -fx-font-size: 14px;"/>

            <ChoiceBox fx:id="role_choice"
                       styleClass="role-choice"
                       style="-fx-background-color: rgba(255, 255, 255, 0.08);
                  -fx-mark-color: white;
                  -fx-text-fill: white;
                  -fx-background-radius: 15;
                  -fx-border-color: rgba(255,255,255,0.15);
                  -fx-border-radius: 15;
                  -fx-padding: 10;
                  -fx-font-size: 14px;" />
        </VBox>

        <Label fx:id="errors" text="Unable to create user"
               style="-fx-text-fill: #ff6b6b;
                      -fx-font-weight: 400;
                      -fx-font-size: 12px;"
               managed="false"
               visible="false"/>

        <Button fx:id="register_button" text="Create user" onAction="#addUser"
                style="-fx-background-color: white;
                       -fx-text-fill: black;
                       -fx-background-radius: 15;
                       -fx-font-weight: 700;
                       -fx-font-size: 15px;
                       -fx-padding: 16 0;
                       -fx-max-width: Infinity;
                       -fx-cursor: hand;"/>

        <Button fx:id="back_button" text="Back" onAction="#goBack"
                style="-fx-background-color: transparent;
                       -fx-text-fill: rgba(255,255,255,0.75);
                       -fx-border-color: rgba(255,255,255,0.15);
                       -fx-border-radius: 15;
                       -fx-background-radius: 15;
                       -fx-font-weight: 700;
                       -fx-font-size: 14px;
                       -fx-padding: 14 24;
                       -fx-cursor: hand;"/>
    </VBox>
</StackPane>